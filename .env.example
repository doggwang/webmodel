# 后端配置
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# 数据库配置
DATABASE_URL=postgresql://suweb:${POSTGRES_PASSWORD}@postgres:5432/suweb
POSTGRES_PASSWORD=your_secure_password_here

# Redis配置
REDIS_URL=redis://redis:6379

# MinIO配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your_secure_minio_secret_key_here
MINIO_BUCKET=suweb-models
MINIO_ROOT_PASSWORD=your_secure_minio_password_here

# JWT配置
JWT_SECRET=your_secure_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=7d

# 文件上传配置
MAX_FILE_SIZE=524288000
ALLOWED_FILE_TYPES=.skp

# 安全配置
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100